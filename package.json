{
  "name": "mixin-chatbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/server/index.ts",
    "dev": "bun --watch run src/server/index.ts",
    "configure": "bun run scripts/config/configure.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "deadcode": "knip",
    "check": "bun run typecheck && bun test && bun run deadcode"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "hono": "^4.12.32",
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "knip": "latest",
    "typescript": "^5.9.3"
  }
}
